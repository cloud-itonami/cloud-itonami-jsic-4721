{:paths ["src"]
 ;; Zero-dependency on cloud-itonami core still holds (ADR-2607011000,
 ;; reaffirmed for the BCP-precondition case specifically by
 ;; ADR-2607176501): this actor's own capacity-concentration-limit
 ;; invariant and every other governor check is fully standalone pure
 ;; logic requiring only `clojure.string`. cloud-itonami's
 ;; SecurityIncidentGovernor (ADR-2607176500, the circuit-breaker/
 ;; pii-precheck/disclosure-guard/bcp-precondition layer this actor's
 ;; :tenant/jsic "4721" classification participates in via
 ;; `physical-ops-jsics`) is enforced at the cloud-itonami PLATFORM
 ;; layer when this actor onboards as a tenant -- not re-implemented or
 ;; depended on here. See README.md / the ADR for this repo for the
 ;; full boundary rationale.
 ;;
 ;; langgraph IS a real top-level dep now (coldchain.operation/build
 ;; wires a real langgraph-clj StateGraph, mirroring
 ;; cloud-itonami-isic-2813/cloud-itonami-isic-0899's own top-level
 ;; `:deps` entry) -- langgraph brings langchain transitively (both
 ;; zero-/single-dep, all .cljc -> portable to JVM / SCI /
 ;; ClojureScript / GraalVM), so this actor's zero-cloud-itonami-dep
 ;; boundary is unaffected; only the langgraph-clj actor-runtime dep
 ;; changed, not a business dependency on cloud-itonami itself.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}}
 :aliases
 {:dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  :run {:main-opts ["-m" "coldchain.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
